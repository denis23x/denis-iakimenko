---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import "@/styles/typography.css";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout
  title="Denis Iakimenko — Fullstack Developer: TypeScript, Next.js, NestJS, Supabase, DevOps, AI integrations"
  description="Fullstack developer shipping products end-to-end since 2016. TypeScript, Next.js, NestJS, PostgreSQL. Open to freelance, contract, and full-time roles."
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose prose-img:border-0 mb-12 max-w-app">
      <h1 class="text-2xl font-semibold sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
