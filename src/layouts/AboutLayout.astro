---
import { getCollection } from "astro:content";
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import "@/styles/typography.css";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
---

<Layout
  title="Denis Iakimenko — Fullstack Developer: TypeScript, Next.js, NestJS, Supabase, DevOps, AI integrations"
  description="Fullstack developer shipping products end-to-end since 2016. TypeScript, Next.js, NestJS, PostgreSQL. Open to freelance, contract, and full-time roles."
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose prose-img:border-0 mb-12 max-w-app">
      <h1 class="text-2xl font-semibold sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>

    {
      featuredPosts.length > 0 && (
        <section id="featured" class:list={["pt-12 pb-6"]}>
          <h2 class="text-2xl font-semibold tracking-wide">Core Articles</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
